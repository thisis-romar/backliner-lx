{
  "name": "backliner-lx",
  "version": "1.0.0",
  "description": "LX floor package — Tourist @ Mod Club, June 26 2026",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "render": "node scripts/render.js",
    "split": "python3 scripts/split-the-views/scripts/split_the_views.py --input output/lx-floor-package.png --outdir output/split --png --expected 3 --extract-title-blocks --strip-header-footer --extract-legend --svg --svg-layers --debug-overlays",
    "extract": "npm run render && npm run split",
    "extract:hd": "node scripts/render.js --dpi 300 && npm run split"
  },
  "dependencies": {
    "sharp": "^0.35.2"
  }
}
